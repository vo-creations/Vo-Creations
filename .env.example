# vocreations.com — environment variables
# Set the real values in Vercel (project: mohios/vocreations). This file is the
# single source of truth for WHICH vars the app uses; `npm run docs:check` fails
# if code references a var that is not listed here.

# Stripe webhook (app/api/stripe-webhook/route.js)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mercury bank webhook (app/api/mercury-webhook/route.js)
MERCURY_WEBHOOK_SECRET=

# Slack Incoming Webhook for payment notifications (Stripe + Mercury, posts to #ka-ching)
SLACK_WEBHOOK_URL=

# ── Creator Data Platform (Drizzle + Supabase Postgres) ──────────────────────
# These are injected automatically by the Vercel→Supabase integration. Pull them
# locally with:  vercel env pull .env.local  (do NOT paste secrets by hand).
#   POSTGRES_URL              pooled (port 6543, Transaction pooler) → runtime, lib/db/client.ts
#   POSTGRES_URL_NON_POOLING  direct (port 5432)                     → migrations, drizzle.config.ts
# Also injected: POSTGRES_PRISMA_URL, POSTGRES_HOST/PASSWORD/DATABASE, SUPABASE_* keys.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Supabase Auth — magic-link login for the gated leaderboard (Phase 3).
# Injected by the integration; browser-safe (NEXT_PUBLIC_*). Used by lib/supabase/*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional manual overrides (win over POSTGRES_* if set):
DATABASE_URL=
DATABASE_URL_DIRECT=

# Sideshift ingest adapter (lib/ingest/sideshift.ts + scripts/probe-sideshift.mjs)
SIDESHIFT_API_KEY=
SIDESHIFT_BASE_URL=
# Auth shape — defaults work for Bearer tokens; override only if the probe shows 401.
SIDESHIFT_AUTH_HEADER=
SIDESHIFT_AUTH_SCHEME=

# Protects the daily sync cron route (/api/cron/sync). Vercel Cron sends this as a
# Bearer token; set the same value in Vercel's Cron settings.
CRON_SECRET=

# Unused — only referenced by removed code; safe to delete from Vercel:
#   STRIPE_PRICE_FULL, STRIPE_PRICE_PLAN  (removed website checkout)
#   GOOGLE_SHEET_WEBHOOK                  (removed Sheets logging)
#   LEADERBOARD_DATA_URL, LEADERBOARD_PASSWORD  (removed leaderboard, rebuild pending)
